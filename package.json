{
  "name": "decky-video-uploader",
  "version": "0.0.1",
  "description": "Export saved gameplay videos as MP4 and upload them to YouTube directly from Game Mode.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SootyOwl/decky-video-uploader.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "steam-deck",
    "video",
    "youtube"
  ],
  "author": "SootyOwl",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/SootyOwl/decky-video-uploader/issues"
  },
  "homepage": "https://github.com/SootyOwl/decky-video-uploader#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "rollup": "^4.59.0",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
